msgid "data"
msgstr "Dados"

msgid "Convert to R Date-Time"
msgstr "Converter para Data-Hora do R"

msgid "Select an object"
msgstr "Selecione um objeto"

msgid "Data vector to convert"
msgstr "Vetor de dados a converter"

msgid "Original format of the data"
msgstr "Formato original dos dados"

msgid "Excel (numeric)"
msgstr "Excel (numérico)"

msgid "SPSS (numeric datetime)"
msgstr "SPSS (data/hora numérica)"

msgid "Stata (numeric datetime in milliseconds)"
msgstr "Stata (data/hora numérica em milissegundos)"

msgid "SAS (numeric datetime)"
msgstr "SAS (data/hora numérica)"

msgid "R numeric (seconds since 1970-01-01)"
msgstr "R numérico (segundos desde 1970-01-01)"

msgid "R character (e.g., '2025-11-21 15:30:00')"
msgstr "R caractere (ex., '2025-11-21 15:30:00')"

msgid "R Date object"
msgstr "Objeto Date do R"

msgid "Save result as"
msgstr "Salvar resultado como"

msgid "Convert to R Date-Time (POSIXct)"
msgstr "Converter para Data-Hora do R (POSIXct)"

msgid "Converts a vector of date/time data from various common formats (like numeric values from Excel, SPSS, Stata, SAS, or R's own character/Date formats) into R's standard POSIXct date-time object."
msgstr "Converte um vetor de dados de data/hora de vários formatos comuns (como valores numéricos do Excel, SPSS, Stata, SAS ou os próprios formatos character/Date do R) para o objeto de data-hora POSIXct padrão do R."