msgid "data"
msgstr "Données"

msgid "Convert to R Date-Time"
msgstr "Convertir en Date-Heure R"

msgid "Select an object"
msgstr "Sélectionner un objet"

msgid "Data vector to convert"
msgstr "Vecteur de données à convertir"

msgid "Original format of the data"
msgstr "Format d'origine des données"

msgid "Excel (numeric)"
msgstr "Excel (numérique)"

msgid "SPSS (numeric datetime)"
msgstr "SPSS (date-heure numérique)"

msgid "Stata (numeric datetime in milliseconds)"
msgstr "Stata (date-heure numérique en millisecondes)"

msgid "SAS (numeric datetime)"
msgstr "SAS (date-heure numérique)"

msgid "R numeric (seconds since 1970-01-01)"
msgstr "R numérique (secondes depuis 1970-01-01)"

msgid "R character (e.g., '2025-11-21 15:30:00')"
msgstr "R caractère (ex., '2025-11-21 15:30:00')"

msgid "R Date object"
msgstr "Objet Date R"

msgid "Save result as"
msgstr "Enregistrer le résultat sous"

msgid "Convert to R Date-Time (POSIXct)"
msgstr "Convertir en Date-Heure R (POSIXct)"

msgid "Converts a vector of date/time data from various common formats (like numeric values from Excel, SPSS, Stata, SAS, or R's own character/Date formats) into R's standard POSIXct date-time object."
msgstr "Convertit un vecteur de données de date/heure de divers formats courants (tels que les valeurs numériques d'Excel, SPSS, Stata, SAS, ou les propres formats caractère/Date de R) en l'objet date-heure POSIXct standard de R."