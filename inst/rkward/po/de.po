msgid "data"
msgstr "Daten"

msgid "Convert to R Date-Time"
msgstr "In R Datum-Uhrzeit umwandeln"

msgid "Select an object"
msgstr "Ein Objekt auswählen"

msgid "Data vector to convert"
msgstr "Zu konvertierender Datenvektor"

msgid "Original format of the data"
msgstr "Ursprüngliches Format der Daten"

msgid "Excel (numeric)"
msgstr "Excel (numerisch)"

msgid "SPSS (numeric datetime)"
msgstr "SPSS (numerische Datum-Uhrzeit)"

msgid "Stata (numeric datetime in milliseconds)"
msgstr "Stata (numerische Datum-Uhrzeit in Millisekunden)"

msgid "SAS (numeric datetime)"
msgstr "SAS (numerische Datum-Uhrzeit)"

msgid "R numeric (seconds since 1970-01-01)"
msgstr "R numerisch (Sekunden seit 1970-01-01)"

msgid "R character (e.g., '2025-11-21 15:30:00')"
msgstr "R Zeichen (z.B. '2025-11-21 15:30:00')"

msgid "R Date object"
msgstr "R Date-Objekt"

msgid "Save result as"
msgstr "Ergebnis speichern als"

msgid "Convert to R Date-Time (POSIXct)"
msgstr "In R Datum-Uhrzeit (POSIXct) umwandeln"

msgid "Converts a vector of date/time data from various common formats (like numeric values from Excel, SPSS, Stata, SAS, or R's own character/Date formats) into R's standard POSIXct date-time object."
msgstr "Konvertiert einen Vektor von Datum/Uhrzeit-Daten aus verschiedenen gängigen Formaten (wie numerischen Werten aus Excel, SPSS, Stata, SAS oder R's eigenen Zeichen-/Date-Formaten) in das standardmäßige POSIXct-Datum-Uhrzeit-Objekt von R."